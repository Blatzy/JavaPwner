/*
 * Reggie (Apache River 2.2.3) configuration for the JavaPwner lab.
 *
 * Key settings:
 *   - JRMP transport on port 4162 (separate from Unicast Discovery on 4160)
 *   - Group: "public" (accessible without credentials)
 *   - No persistence (transient — restarts clean)
 *
 * The JrmpExporter forces old JRMP wire protocol so that JavaPwner can
 * perform JRMP DGC dirty() exploitation on the Reggie object endpoint.
 *
 * Attack surface:
 *   javapwner jini scan   -t 127.0.0.1 -p 4160
 *   javapwner jini exploit -t 127.0.0.1 -p 4162 --gadget CommonsCollections6 --cmd '...'
 */
import net.jini.jrmp.JrmpExporter;

com.sun.jini.reggie {
    /* Discovery groups this registrar belongs to */
    initialMemberGroups = new String[] { "public" };

    /* Export the Registrar object via JRMP on a fixed port.
     * Port 4162 is mapped to the host in docker-compose so JavaPwner
     * can reach the JRMP object after scanning port 4160. */
    serverExporter = new JrmpExporter(4162);
}
