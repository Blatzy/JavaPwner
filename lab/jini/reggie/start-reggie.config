/*
 * ServiceStarter configuration — launches TransientRegistrarImpl.
 *
 * The codebase URL is substituted at runtime by start.sh.
 * The REGGIE_CODEBASE placeholder is replaced with the value of
 * $CODEBASE_URL (default: http://127.0.0.1:8085).
 */
import com.sun.jini.start.NonActivatableServiceDescriptor;
import com.sun.jini.start.ServiceDescriptor;

com.sun.jini.start {
    serviceDescriptors = new ServiceDescriptor[] {
        new NonActivatableServiceDescriptor(
            /* codebase: URL clients use to download Reggie proxy classes */
            "REGGIE_CODEBASE/reggie-dl-2.2.3.jar",
            /* policy */
            "/jini/security.policy",
            /* server-side classpath — includes commons-collections so the JRMP
             * DGC channel is exploitable via CC gadget chains */
            "/jini/lib/reggie-2.2.3.jar:/jini/lib/jsk-lib-2.2.3.jar"
            + ":/jini/lib/jsk-platform-2.2.3.jar:/jini/lib/reggie-dl-2.2.3.jar"
            + ":/jini/lib/jini-ext-2.1.jar:/jini/lib/commons-collections-3.1.jar",
            /* implementation class */
            "com.sun.jini.reggie.TransientRegistrarImpl",
            /* impl config args */
            new String[] { "/jini/reggie.config" }
        )
    };
}
